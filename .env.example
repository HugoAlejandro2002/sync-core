APP_NAME="Caja Inteligente API"
APP_ENV="local"
APP_DEBUG=true

# Database. docker-compose maps MySQL to MYSQL_HOST_PORT (default 3306). If you
# already run a local MySQL on 3306, set MYSQL_HOST_PORT=3307 and use 3307 below.
MYSQL_HOST_PORT=3306
DATABASE_URL="mysql+asyncmy://root:password@localhost:3306/caja_inteligente"

# Leave GEMINI_API_KEY as "replace-me" (or empty) to use the fake extraction
# provider — the full flow works with no API spend. Set a real key for Gemini.
GEMINI_API_KEY="replace-me"
GEMINI_MODEL="gemini-2.0-flash"

MEDIA_STORAGE_DRIVER="local"
LOCAL_MEDIA_DIR="./storage/media"

DEFAULT_CURRENCY="BOB"
TIMEZONE="America/La_Paz"

CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
